    <!-- Bug fix 2026-07-11: was "HardcodedFileSeparators" (plural) — verified the real ID is
         singular; the typo meant this entry silently no-op'd since the profile predates this file. -->
    <inspection_tool class="HardcodedFileSeparator" enabled="true" level="ERROR" enabled_by_default="true" />
    <inspection_tool class="HardcodedLineSeparator" enabled="true" level="ERROR" enabled_by_default="true" />

    <!-- ═══ paranoid (WEAK WARNING) — IDE on-demand ════════════════════════ -->
    <!-- Modernization nudges: available as hints, never balance-level noise,
         never a CI blocker. -->
    <inspection_tool class="EnhancedSwitchMigration" enabled="true" level="WEAK WARNING" enabled_by_default="true" />
