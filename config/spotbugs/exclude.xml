<?xml version="1.0" encoding="UTF-8"?>
<!--
  SpotBugs exclusion filter for l-java.

  Add entries here only when SpotBugs produces a confirmed false positive
  that cannot be suppressed inline with @SuppressFBWarnings on the specific
  element. Prefer inline suppression with a justifying comment over blanket
  pattern exclusions here.

  Example entry (do not add without a confirmed false positive):
  <Match>
    <Bug pattern="EXAMPLE_PATTERN"/>
  </Match>
-->
<FindBugsFilter>

    <!--
      Records synthesize their accessors/equals/hashCode/toString, and SpotBugs
      sometimes flags a @SuppressFBWarnings on that generated code as unnecessary —
      a false positive specific to record-generated bytecode, not a real suppression
      to remove.
    -->
    <Match>
        <Bug pattern="US_USELESS_SUPPRESSION_ON_CLASS,US_USELESS_SUPPRESSION_ON_METHOD"/>
    </Match>

    <!--
      Null-safety hand-off to NullAway: this project enforces null-safety via NullAway
      (Error Prone) with JSpecify @NullMarked/@Nullable annotations. SpotBugs' own
      dataflow-based null analysis doesn't understand JSpecify annotations and routinely
      produces findings that conflict with NullAway's. Deferring these three patterns to
      NullAway avoids duplicate/contradictory null-safety findings between the two tools.
    -->
    <Match>
        <Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE,NP_PARAMETER_MUST_BE_NONNULL_BUT_MARKED_AS_NULLABLE,RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE"/>
    </Match>

</FindBugsFilter>
