<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
    "-//Checkstyle//DTD SuppressionFilter Configuration 1.0//EN"
    "https://checkstyle.org/dtds/suppressions_1_0.dtd">

<!--
  Checkstyle suppressions.

  Add project-specific suppressions here only when a rule genuinely cannot
  apply (e.g. generated code). Do NOT suppress violations to avoid fixing them.
-->
<suppressions>

    <!-- Test code relaxations -->
    <suppress checks="MagicNumber"
              files="[\\/]src[\\/]test[\\/]java[\\/].*"/>
    <suppress checks="MultipleStringLiterals"
              files="[\\/]src[\\/]test[\\/]java[\\/].*"/>
    <suppress checks="IllegalCatch"
              files="[\\/]src[\\/]test[\\/]java[\\/].*"/>
    <suppress checks="IllegalThrows"
              files="[\\/]src[\\/]test[\\/]java[\\/].*"/>

    <!-- UnusedLocalVariable: var _ = ... idiom for discarding @CheckReturnValue results -->
    <suppress checks="UnusedLocalVariable"
              files="[\\/]src[\\/]test[\\/]java[\\/].*"/>

</suppressions>
